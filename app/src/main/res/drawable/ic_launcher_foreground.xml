<!-- Launcher foreground: a simple soft-red camera lens mark on transparency. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Outer lens ring. -->
    <path
        android:strokeColor="#D65A5A"
        android:strokeWidth="5"
        android:fillColor="#00000000"
        android:pathData="M54,30 m-22,0 a22,22 0 1,0 44,0 a22,22 0 1,0 -44,0" />

    <!-- Inner aperture dot. -->
    <path
        android:fillColor="#D65A5A"
        android:pathData="M54,30 m-9,0 a9,9 0 1,0 18,0 a9,9 0 1,0 -18,0" />

    <!-- A short base line to hint at a photo frame. -->
    <path
        android:fillColor="#8A4040"
        android:pathData="M34,70 h40 v6 h-40 z" />
</vector>
