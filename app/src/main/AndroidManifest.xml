<?xml version="1.0" encoding="utf-8"?>
<!--
  No INTERNET permission is requested anywhere. The app cannot phone home,
  and this manifest is the proof. Everything happens on the device.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
      Only needed to save into the gallery on Android 9 and below. On Android 10+
      scoped storage means no permission at all. Capped at API 28 so newer
      devices never even see the request. Still no INTERNET permission anywhere.
    -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.ElendheimPictureEditor">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.ElendheimPictureEditor">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
